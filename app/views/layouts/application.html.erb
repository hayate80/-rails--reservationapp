<!DOCTYPE html>
<html>
  <head>
    <title>Reservationapp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
    <header>
      <h1>Potepan travel</h1>
      <nav>
        <% if user_signed_in? %>
          <div class="mypage-btn-container" id="mypageBtnContainer">
            <div><%= image_tag current_user.icon_img_url(:icon), class: "rounded-circle" %> <%= current_user.name %></div>
	          <ul class="mypage-dropdown" id="mypageDropdown">
              <li><%= link_to '施設の新規登録', new_room_path %></li>
              <li><%= link_to '予約済み一覧', reservations_path %></li>
              <li><%= link_to '登録済み一覧', rooms_path %></li>
	            <li><%= link_to 'アカウント設定', users_profile_path %></li>
	            <li><%= link_to 'ログアウト', destroy_user_session_path, method: :delete %></li>
	          </ul>
          </div>


        <% else %>
          <%= link_to 'サインアップ', new_user_registration_path %>
          <%= link_to 'ログイン', new_user_session_path %>
        <% end %>
      </nav>
    </header>

    <%= yield %>

    <footer>
      <h1>Potepan travel</h1>
      <p>素敵な旅をあなたに<p>
    </footer>

  </body>
</html>
